# Backend Environment Configuration for Recipe Recommender v2.0
# Copy this to .env and update with your settings

# Flask Configuration
FLASK_ENV=development
FLASK_APP=app_v2.py
PORT=5000
DEBUG=True

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=recipe_recommender
DB_POOL_SIZE=8

# Security
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60

# ML Configuration
ML_MODEL_LIMIT=5000
ML_MAX_FEATURES=5000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text
ERROR_LOG_FILE=logs/errors.log
